{
    "name":  "@markmap/app",
    "private":  true,
    "version":  "0.18.12",
    "description":  "Markmap AI desktop app (Electron)",
    "main":  "dist-electron/main.js",
    "scripts":  {
                    "dev":  "vite",
                    "dev:debug":  "cross-env VSCODE_DEBUG=true vite",
                    "build":  "vite build",
                    "preview":  "vite preview",
                    "rebuild-pty":  "electron-rebuild -f -w node-pty",
                    "postinstall":  "electron-rebuild -f -w node-pty",
                    "test":  "vitest run",
                    "test:watch":  "vitest",
                    "test:coverage":  "vitest run --coverage",
                    "test:e2e":  "pnpm run build \u0026\u0026 playwright test",
                    "test:e2e:ui":  "pnpm run build \u0026\u0026 playwright test --ui"
                },
    "dependencies":  {
                         "@codemirror/commands":  "^6.10.3",
                         "@codemirror/lang-markdown":  "^6.5.0",
                         "@codemirror/language":  "^6.12.3",
                         "@codemirror/state":  "^6.6.0",
                         "@codemirror/theme-one-dark":  "^6.1.3",
                         "@codemirror/view":  "^6.40.0",
                         "markmap-lib":  "^0.18.12",
                         "markmap-view":  "^0.18.12",
                         "node-pty":  "^1.0.0",
                         "uuid":  "^13.0.0",
                         "xterm":  "^5.3.0",
                         "xterm-addon-fit":  "^0.8.0",
                         "xterm-addon-web-links":  "^0.9.0",
                         "xterm-addon-webgl":  "^0.16.0"
                     },
    "devDependencies":  {
                            "@electron/rebuild":  "^3.6.0",
                            "@playwright/test":  "^1.58.2",
                            "@types/node":  "^25.5.0",
                            "@types/react":  "^19.2.14",
                            "@types/react-dom":  "^19.2.3",
                            "@vitejs/plugin-react":  "^4.2.0",
                            "@vitest/coverage-v8":  "^3.2.3",
                            "cross-env":  "^10.1.0",
                            "electron":  "^28.2.0",
                            "electron-builder":  "^24.9.1",
                            "react":  "^18.2.0",
                            "react-dom":  "^18.2.0",
                            "typescript":  "^6.0.2",
                            "vite":  "^5.1.0",
                            "vite-plugin-electron":  "^0.28.4",
                            "vite-plugin-electron-renderer":  "^0.14.5",
                            "vitest":  "^3.2.3"
                        },
    "build":  {
                  "appId":  "com.markmap.app",
                  "productName":  "Markmap AI",
                  "directories":  {
                                      "output":  "release"
                                  },
                  "files":  [
                                "dist",
                                "dist-electron"
                            ],
                  "win":  {
                              "target":  "nsis"
                          }
              }
}